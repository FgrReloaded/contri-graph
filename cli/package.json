{
  "name": "contri-graph",
  "version": "1.0.0",
  "description": "Show your GitHub contribution graph in the terminal",
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x bin/contri-graph.js",
    "clean": "rm -rf bin",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "contri-graph": "./bin/contri-graph.js"
  },
  "keywords": [
    "github",
    "contributions",
    "terminal",
    "cli",
    "graph"
  ],
  "author": "FgrReloaded",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FgrReloaded/contri-graph"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  },
  "files": [
    "bin/",
    "contri-graph.sh"
  ]
}
